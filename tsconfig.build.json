{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": [
    "src/core/**/*.ts",
    "src/materials/**/*.ts",
    "src/objects/**/*.ts",
    "src/renderers/**/*.ts",
    "src/utils/**/*.ts",
    "src/index.ts"
  ],
  "exclude": [
    "src/main.ts",
    "src/pages/**/*.ts"
  ]
}
