{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "raw2d-canvas": ["../canvas/src/index.ts"],
      "raw2d-core": ["../core/src/index.ts"],
      "raw2d-effects": ["../effects/src/index.ts"],
      "raw2d-interaction": ["../interaction/src/index.ts"],
      "raw2d-mcp": ["../mcp/src/index.ts"],
      "raw2d-react": ["../react/src/index.ts"],
      "raw2d-sprite": ["../sprite/src/index.ts"],
      "raw2d-text": ["../text/src/index.ts"],
      "raw2d-webgl": ["../webgl/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["dist"]
}
