{
  "name": "raw2d-sprite",
  "version": "1.2.9",
  "description": "Sprite and texture package for Raw2D.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE",
    "TRADEMARKS.md"
