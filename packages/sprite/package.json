  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "raw2d-core": "1.2.9"
  },
  "author": "Aditya Nandlal",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bestmaa/raw2d.git"
  },
  "bugs": {
    "url": "https://github.com/bestmaa/raw2d/issues"
  },
  "homepage": "https://raw2d.com/doc",
  "keywords": [
    "sprite",
    "texture",
    "atlas",
    "2d",
    "typescript",
    "raw2d"
  ]
}
