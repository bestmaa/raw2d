{
  "name": "raw2d-mcp",
  "version": "1.5.1",
  "description": "MCP tools and manifests for Raw2D scene automation.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "bin": {
    "raw2d-mcp": "./dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE",
    "TRADEMARKS.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "raw2d-core": "1.5.1"
  },
  "author": "Aditya Nandlal",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bestmaa/raw2d.git"
  },
  "bugs": {
    "url": "https://github.com/bestmaa/raw2d/issues"
  },
  "homepage": "https://raw2d.com/doc",
  "keywords": [
    "mcp",
    "automation",
    "2d",
    "typescript",
    "raw2d"
  ]
}
