{
  "name": "raw2d-react",
  "version": "0.9.3",
  "description": "React bridge package scaffold for Raw2D.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
